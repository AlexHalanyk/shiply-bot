TELEGRAM_TOKEN=your-telegram-bot-token
GEMINI_API_KEY=your-gemini-api-key

# LLM backend for job relevance filtering: 'gemini', 'ollama', or 'cascade'
# (cascade: gemma decides first, only its approvals go to gemini for a final verdict)
LLM_BACKEND=gemini

# Needed when LLM_BACKEND is 'ollama' or 'cascade'
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b
